# Copy to .env and fill in real values. Never commit the real .env.
AIRTABLE_TOKEN=pat_xxxxx
AIRTABLE_BASE_ID=app_xxxxx

# --- Legacy HTTP Basic — remove after cutover ---
# Kept only for the dual-mode window. At cutover, drop WEB_PASSWORD and set
# LEGACY_BASIC_FALLBACK=false.
WEB_USERNAME=admin
WEB_PASSWORD=change_me

# --- Supabase auth (per-user drinks roles via user_app_roles, RLS) ---
# Same Supabase project as tenancy-master. The drinks app holds ONLY the public
# anon key + URL — NEVER the service-role key.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx_public_anon_key
LEGACY_BASIC_FALLBACK=true
TENANCY_ADMIN_URL=https://tenancy-master.onrender.com/admin
